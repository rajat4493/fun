# Use one or both. The API route prefers Anthropic if present, otherwise OpenAI.
ANTHROPIC_API_KEY=your_anthropic_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6

OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o-mini

# TMDB: use either key — TMDB_API_KEY (v3, shorter) or TMDB_READ_ACCESS_TOKEN (v4 bearer, starts with eyJ...)
# Both work. Get them at https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_v3_api_key_here
TMDB_READ_ACCESS_TOKEN=your_tmdb_v4_read_access_token_here
